#!/usr/bin/env bash
# shellcheck disable=SC1090

path="$BASH_IT/bash_it.sh"
if [ -f "$path" ]; then
	source "$path"

	declare -a aliases=()
	aliases+=("apt")
	aliases+=("bash-it")
	aliases+=("clipboard")
	aliases+=("curl")
	aliases+=("general")
	aliases+=("npm")
	aliases+=("tmux")
	aliases+=("vim")
	for alias_ in "${aliases[@]}"; do
		bash-it enable alias "$alias_"
	done

	declare -a completions=()
	completions+=("bash-it")
	completions+=("conda")
	completions+=("git")
	for completion in "${completions[@]}"; do
		bash-it enable completion "$completion"
	done

	declare -a plugins=()
	plugins+=("alias-completion")
	plugins+=("base")
	plugins+=("fzf")
	plugins+=("history")
	plugins+=("man")
	plugins+=("sudo")
	plugins+=("tmux")
	plugins+=("xterm")
	for plugin in "${plugins[@]}"; do
		bash-it enable plugin "$plugin"
	done
else
	printf "%(%Y-%m-%d %H:%M:%S)T: Unable to find %s\n" -1 "$path"
fi
