#!/usr/bin/env bash
# shellcheck source=/dev/null

# === curl and git ===

ensure_apt_install() {
	pkg="$1"
	repo="$2"
	if ! dpkg -s "$pkg" >/dev/null 2>&1; then
		if [ -n "$repo" ]; then
			sudo add-apt-repository -y "$repo"
		fi
		sudo apt update
		sudo apt -y install "$pkg"
	fi
}

ensure_apt_install curl
ensure_apt_install git

# === repo ===

export PATH_DOTFILES="${PATH_DOTFILES:-$HOME/dotfiles}"
if ! [ -d "$PATH_DOTFILES" ]; then
	git clone --recuse-submodules https://github.com/dycw/dotfiles.git "$PATH_DOTFILES"
fi

# === symlinks ===

make_link() {
	file="$1"
	link="$2"
	mkdir -p "$(dirname "$link")"
	ln -f -s "$file" "$link"
}

process_link() {
	file="$1"
	link="$2"
	if [ -f "$link" ]; then
		if [ -L "$link" ]; then
			old="$(readlink "$link")"
			if [ "$old" != "$file" ]; then
				echo "\
Re-directing symlink:
       $link
old -> $old
new -> $file"
				make_link "$file" "$link"
			fi
		else
			echo "\
Overriding existing file with symlink:
   $link
-> $file"
			make_link "$file" "$link"
		fi
	else
		echo "\
Making symlink:
   $link
-> $file"
		make_link "$file" "$link"
	fi
}

find "$PATH_DOTFILES" -name .mypy_cache -type d -prune -exec rm -rf {} \;

process_root() {
	home_name="$1"
	while IFS= read -d '' -r home_path; do
		while IFS= read -d '' -r rel_path; do
			abs_path="$(realpath "$rel_path")"
			if [ -f "$abs_path" ]; then
				link="$HOME/$(realpath --relative-to="$home_path" "$abs_path")"
				process_link "$abs_path" "$link"
			fi
		done < <(find "$home_path" -print0 -type f -or -type l)
	done < <(find "$PATH_DOTFILES" -name "$home_name" -print0 -type d)
}

process_root home
process_root home.local

while IFS= read -d '' -r __submodules; do
	__tmux_conf="$__submodules/.tmux/.tmux.conf"
	if [ -f "$__tmux_conf" ]; then
		process_link "$__tmux_conf" "$HOME/.tmux.conf"
	fi
done < <(find "$PATH_DOTFILES" -name submodules -not -path "*/.git/*" -print0 -type d)

# === brew (needs confirmation) ===

__linuxbrew="/home/linuxbrew"
if ! [ -d "$__linuxbrew" ]; then
	curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh
fi

ensure_brew_install() {
	if (command -v brew >/dev/null 2>&1) && ! (brew list "$1" >/dev/null 2>&1); then
		brew install "$@"
	fi
}

ensure_apt_install build-essential
ensure_brew_install gcc

# === brew: fzf ===

ensure_brew_install fzf
__install="$(brew --prefix)/opt/fzf/install"
if [ -f "$__install" ] && ! [ -d "${XDG_CONFIG_HOME:-$HOME/.config}/fzf" ]; then
	"$__install" --xdg --key-bindings --completion --no-update-rc
fi

# === brew: zsh ===

ensure_brew_install zsh
if (command -v zsh >/dev/null 2>&1) && ! (grep -q zsh "/etc/shells"); then
	command -v zsh | sudo tee -a /etc/shells
	sudo chsh -s "$(command -v zsh)" "${USER}"
fi

# === brew: rest of them ===

ensure_brew_install bandwhich
ensure_brew_install bat
ensure_brew_install bingrep
ensure_brew_install broot
ensure_brew_install ctags
ensure_brew_install ddgr
ensure_brew_install direnv
ensure_brew_install diskonaut
ensure_brew_install dust
ensure_brew_install elm
ensure_brew_install exa
ensure_brew_install fd
ensure_brew_install fpp
ensure_brew_install git
ensure_brew_install git-crypt
ensure_brew_install git-delta
ensure_brew_install googler
ensure_brew_install grex
ensure_brew_install hub
ensure_brew_install hyperfine
ensure_brew_install mdcat
ensure_brew_install neovim
ensure_brew_install node
ensure_brew_install pipx
ensure_brew_install procs
ensure_brew_install ripgrep
ensure_brew_install sd
ensure_brew_install shellcheck
ensure_brew_install shfmt
ensure_brew_install speedtest-cli
ensure_brew_install spotify-tui
ensure_brew_install starship
ensure_brew_install tealdeer
ensure_brew_install tmux
ensure_brew_install tokei
ensure_brew_install tree
ensure_brew_install watchexec
ensure_brew_install yarn
ensure_brew_install zoxide
ensure_brew_install clementtsang/bottom/bottom
ensure_brew_install eth-p/software/bat-extras

# === conda ===

__miniconda3="$HOME/miniconda3"
if ! [ -d "$__miniconda3" ]; then
	__miniconda="$(mktemp -d)/miniconda.sh"
	wget https://repo.anaconda.com/miniconda/Miniconda3-latest-Linux-x86_64.sh \
		-O "$__miniconda"
	bash "$__miniconda" -b -u -p "$__miniconda3"
fi

# === dropbox ===

__data_dir=/data/derek
if [ -d "$__data_dir" ]; then
	__dropboxd="$__data_dir/.dropbox-dist/dropboxd"
	if ! [ -f "$__dropboxd" ]; then
		cd "$__data_dir" || exit
		wget -O - "https://www.dropbox.com/download?plat=lnx.x86_64" | tar xzf -
		HOME="$__data_dir" "$__dropboxd"
	fi
fi

# === pynvim ===

__brew_python="$(brew --prefix)/bin/python3)"
__pynvim="$XDG_CACHE_HOME/pynvim"
__bin="$__pynvim/bin"
__pynvim_python="$__bin/python"
if [ -f "$__brew_python" ] && ! [ -f "$__pynvim_python" ]; then
	mkdir -p "$__pynvim"
	cd "$__pynvim" || exit
	"$__brew_python" -m venv .
	__pip="$__bin/pip"
	if [ -f "$__pip" ]; then
		"$__pip" install --upgrade pip
		"$__pip" install neovim
	fi
fi

# === vim-plug ===

for __dir in "$HOME/.vim" "${XDG_DATA_HOME:-$HOME/.local/share}/nvim/site"; do
	__plug_vim="$__dir/autoload/plug.vim"
	if ! [ -f "$__plug_vim" ]; then
		curl -fLo "$__plug_vim" --create-dirs \
			https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
	fi
done

# === wally ===

ensure_apt_install libusb-dev
__wally_rules=/etc/udev/rules.d/50-wally.rules
if ! [ -f "$__wally_rules" ]; then
	sudo tee -a "$__wally_rules" >/dev/null 2>&1 <<END
# Teensy rules for the Ergodox EZ
ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="04[789B]?", ENV{ID_MM_DEVICE_IGNORE}="1"
ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="04[789A]?", ENV{MTP_NO_PROBE}="1"
SUBSYSTEMS=="usb", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="04[789ABCD]?", MODE:="0666"
KERNEL=="ttyACM*", ATTRS{idVendor}=="16c0", ATTRS{idProduct}=="04[789B]?", MODE:="0666"

# STM32 rules for the Moonlander and Planck EZ
SUBSYSTEMS=="usb", ATTRS{idVendor}=="0483", ATTRS{idProduct}=="df11", \
    MODE:="0666", \
    SYMLINK+="stm32_dfu"
END
	cd /usr/local/bin || exit
	sudo wget https://configure.ergodox-ez.com/wally/linux -O wally
	sudo chmod +x wally
	sudo groupadd plugdev
	sudo usermod -aG plugdev "$USER"
fi

# === zinit ===

if ! [ -d "$HOME/.zinit" ]; then
	__url=https://raw.githubusercontent.com/zdharma/zinit/master/doc/install.sh
	curl -fsSL "$__url"
fi

# === cargo ===

ensure_cargo_install() {
	if (command -v cargo >/dev/null 2>&1) &&
		! (command -v "$1" >/dev/null 2>&1); then
		cargo install "$1"
	fi
}

ensure_cargo_install gitui
ensure_cargo_install gitweb
ensure_cargo_install rmesg

# === gem ===

ensure_gem_install() {
	if (command -v gem >/dev/null 2>&1) &&
		! (command -v "$1" >/dev/null 2>&1); then
		gem install "$1"
	fi
}

ensure_gem_install mdl

# === npm ===

ensure_npm_install() {
	if (command -v npm >/dev/null 2>&1) &&
		! (npm ls -g | grep "$1" >/dev/null 2>&1); then
		npm install -g "$1"
	fi
}

ensure_npm_install pyright
ensure_npm_install @stoplight/spectral

# === pipx ===

ensure_pipx_install() {
	if (command -v pipx >/dev/null 2>&1) &&
		! (pipx list | grep "package $1" >/dev/null 2>&1); then
		pipx install "$1"
		if [ "$1" == flake8 ]; then
			url=https://raw.githubusercontent.com/dycw/pre-commit-hooks/master/flake8-extensions
			for ext in $(curl $url); do
				pipx inject "$1" "$ext"
			done
		fi
	fi
}

ensure_pipx_install autoimport
ensure_pipx_install black
ensure_pipx_install bump2version
ensure_pipx_install flake8
ensure_pipx_install pre-commit
ensure_pipx_install pyre-check
ensure_pipx_install reorder-python-imports
ensure_pipx_install vim-vint
ensure_pipx_install yamllint

# === apt ===

ensure_apt_install alacritty ppa:aslatter/ppa
ensure_apt_install pdfarranger ppa:linuxuprisinig/apps
ensure_apt_install qutebrowser
ensure_apt_install sqlitebrowser ppa:linuxgndu/sqlitebrowser
ensure_apt_install texlive-xetex
ensure_apt_install vim
ensure_apt_install chrome-gnome-shell # screenshot locations
ensure_apt_install gnome-tweaks       # screenshot locations

# === apt: chrome ===

if ! command -v google-chrome >/dev/null 2>&1; then
	tmp_dir="$(mktemp -d)"
	cd "$tmp_dir" || exit
	__url=https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
	wget "$__url"
	sudo dpkg -i google-chrome-stable_current_amd64.deb
fi

# === apt: nordvpn ===

if ! command -v nordvpn >/dev/null 2>&1; then
	curl -sSf https://downloads.nordcdn.com/apps/linux/install.sh
fi

# === snap ===

ensure_snap_install() {
	pkg="$1"
	if ! command -v "$pkg" >/dev/null 2>&1; then
		shift
		sudo snap install "$pkg" "$@"
	fi
}

ensure_snap_install insomnia-designer
ensure_snap_install signal-desktop
# ensure_snap_install transmission --beta

# === SSH key ===

ensure_brew_install xclip

__config_local="${XDG_CONFIG_HOME:-$HOME/.config}/git/config.local"
if ! [ -f "$__config_local" ]; then
	tee -a "$__config_local" >/dev/null 2>&1 <<END
[user]
  name = Derek Wan
  email = d.wan@icloud.com
END
fi

__private="$HOME/.ssh/id_rsa"
__public="$__private.pub"
if ! [ -f "$__public" ]; then
	ssh-keygen -b 4096 -f "$__private" -q -t rsa -C d.wan@icloud.com -N '' \
		<<<y >/dev/null 2>&1
	ssh-agent -s
	ssh-add
	xclip -sel clip <"$__public"
	firefox "https://github.com/settings/keys"
	echo "Please add your SSH key (copied) to GitHub"
	cd "$PATH_DOTFILES" || exit
	git remote set-url origin git@github.com:dycw/dotfiles.git
fi
