#!/usr/bin/env bash

path="$(git rev-parse --show-toplevel)/.bumpversion.cfg"
if [ -f "$path" ]; then
	case "$1" in
	mi*)
		part="minor"
		;;
	ma*)
		part="major"
		;;
	*)
		part="patch"
		;;
	esac
	bump2version --allow-dirty --config-file="$path" "$part"
else
	printf "Unable to find %s\n" "$path"
fi
