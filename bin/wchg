#!/usr/bin/env bash

if ! command -v when-changed >/dev/null 2>&1; then
	printf "when-changed not found; installing...\n"
	pip install when-changed
	printf "when-changed installed...\n"
fi

path="$1"
shift
cmd="printf \"\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\n\"; printf \"%f changed\n\"; "
for i in "$@"; do
	cmd+=" $i"
done

when-changed -1 -r -s -v "$path" -c "$cmd"
