#!/usr/bin/env bash
# shellcheck disable=SC1090,SC1091

case $- in
*i*) ;;
*) return ;;
esac

#### mode switch files ########################################################

for _f in "${HOME}"/.mode.sw*; do
	[ -e "${_f}" ] && rm -v -- "${_f}"
done
unset _f

__source_first() {
	_f
	for _f in "$@"; do
		[ -f "${_f}" ] && {
			. "${_f}"
			return 0
		}
	done
	return 1
}

#### completion ###############################################################

if ! shopt -oq posix; then
	_brew_prefix=''
	command -v brew >/dev/null 2>&1 && _brew_prefix=$(brew --prefix 2>/dev/null)
	__source_first \
		"${_brew_prefix}/etc/profile.d/bash_completion.sh" \
		/home/linuxbrew/.linuxbrew/etc/profile.d/bash_completion.sh \
		/usr/share/bash-completion/bash_completion \
		/etc/bash_completion || true
	if [ -n "${_brew_prefix}" ]; then
		# Create the brew completion symlink if missing so completion works on first shell open.
		[ -e "${_brew_prefix}/etc/bash_completion.d/brew" ] ||
			brew completions link >/dev/null 2>&1 || true
		__source_first \
			"${_brew_prefix}/etc/bash_completion.d/brew" \
			"${_brew_prefix}/Library/Homebrew/completions/bash/brew" || true
		__source_first \
			"${_brew_prefix}/etc/bash_completion.d/git-completion.bash" \
			/Library/Developer/CommandLineTools/usr/share/git-core/git-completion.bash || true
	fi
	unset _brew_prefix
fi

#### history ##################################################################

HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000
shopt -s histappend

#### readline #################################################################

set -o vi
bind 'set editing-mode vi'
bind -m vi-command '"v": edit-and-execute-command'

#### check window size ########################################################

shopt -s checkwinsize

#### bashrc.d #################################################################

mkdir -p "${HOME}/.bashrc.d"
for _f in "${HOME}"/.bashrc.d/*.sh "${HOME}"/.bashrc.d/*.bash; do
	[ -r "${_f}" ] && [ -f "${_f}" ] && . "${_f}"
done
unset _f
