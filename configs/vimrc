" ── keymaps ───────────────────────────────────────────────────────────────────

" command shortcut
nnoremap ; :

" escape from insert/visual
inoremap jk <Esc>
inoremap kj <Esc>

" copy/paste mode toggle (F2)
function! s:ToggleCopyPasteMode()
  if &number
    set nonumber norelativenumber signcolumn=no paste
    IndentLinesDisable
  else
    set number relativenumber signcolumn=yes nopaste
    IndentLinesEnable
  endif
endfunction
nnoremap <silent> <F2> :call <SID>ToggleCopyPasteMode()<CR>
vnoremap <silent> <F2> :<C-u>call <SID>ToggleCopyPasteMode()<CR>

" global marks: remap lowercase → uppercase so marks persist across files
for s:c in split('abcdefghijklmnopqrstuvwxyz', '\zs')
  execute 'nnoremap m' . s:c . ' m' . toupper(s:c)
  execute "nnoremap '" . s:c . " '" . toupper(s:c)
  execute 'vnoremap m' . s:c . ' m' . toupper(s:c)
  execute "vnoremap '" . s:c . " '" . toupper(s:c)
endfor

