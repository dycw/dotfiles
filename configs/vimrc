" auto-save toggle (<Leader>as)
let s:autosave_on = 0
function! s:ToggleAutoSave()
  if s:autosave_on
    autocmd! AutoSaveGroup
    let s:autosave_on = 0
    echo 'AutoSave disabled'
  else
    augroup AutoSaveGroup
      autocmd!
      autocmd CursorHold,InsertLeave * silent! update
    augroup END
    let s:autosave_on = 1
    echo 'AutoSave enabled'
  endif
endfunction
nnoremap <silent> <Leader>as :call <SID>ToggleAutoSave()<CR>

" ── autocmds ──────────────────────────────────────────────────────────────────
augroup vimrc
  autocmd!

  " equalize windows on resize (VimResized autocmd)
  autocmd VimResized * wincmd =

  " auto-create parent directories on save (mkdir.nvim)
  autocmd BufWritePre * call s:MkdirOnSave()

  " trim trailing whitespace on save
  autocmd BufWritePre * call s:TrimTrailingWhitespace()

augroup END

function! s:MkdirOnSave()
  let dir = expand('<afile>:p:h')
  if !isdirectory(dir)
    call mkdir(dir, 'p')
  endif
endfunction

function! s:TrimTrailingWhitespace()
  let save = winsaveview()
  keeppatterns %s/\s\+$//e
  call winrestview(save)
endfunction

