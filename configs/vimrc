" vimrc — comprehensive config ported from neovim/lazy.nvim

" ── vim-plug bootstrap ───────────────────────────────────────────────────────
let s:plug_file = expand('~/.vim/autoload/plug.vim')
if empty(glob(s:plug_file))
  silent execute '!curl -fLo ' . s:plug_file . ' --create-dirs '
    \ . 'https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

" ── plugins ───────────────────────────────────────────────────────────────────
call plug#begin('~/.vim/plugged')

" UI
Plug 'ghifarit53/tokyonight-vim'
Plug 'itchyny/lightline.vim'
Plug 'ap/vim-buftabline'
Plug 'Yggdroot/indentLine'
Plug 'luochen1990/rainbow'
Plug 'romainl/vim-cool'
Plug 'jeffkreeftmeijer/vim-numbertoggle'

" Navigation and reading
Plug 'preservim/nerdtree'
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'
Plug 'justinmk/vim-sneak'
Plug 'christoomey/vim-tmux-navigator'
Plug 'farmergreg/vim-lastplace'
Plug 'wellle/context.vim'

" Text objects and editing
Plug 'wellle/targets.vim'
Plug 'andymass/vim-matchup'
Plug 'michaeljsmith/vim-indent-object'
Plug 'gcmt/wildfire.vim'
Plug 'tpope/vim-surround'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-abolish'
Plug 'tpope/vim-unimpaired'
Plug 'tpope/vim-eunuch'
Plug 'tpope/vim-sleuth'
Plug 'jiangmiao/auto-pairs'
Plug 'tpope/vim-speeddating'

" Search and replace
Plug 'brooth/far.vim'
Plug 'haya14busa/incsearch.vim'

" Git, buffers, linting, and language support
Plug 'airblade/vim-gitgutter'
Plug 'rhysd/conflict-marker.vim'
Plug 'moll/vim-bbye'
Plug 'dense-analysis/ale'
Plug 'rust-lang/rust.vim'

call plug#end()

" Auto-install missing plugins on startup.
autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)'))
  \| PlugInstall --sync | source $MYVIMRC
  \| endif

" ── leader ────────────────────────────────────────────────────────────────────
let mapleader = ' '
let maplocalleader = ' '

" ── options ───────────────────────────────────────────────────────────────────
" Files and persistence
set nobackup
set nowritebackup
set noswapfile
set undofile
let &undodir = expand('~/.vim/undodir')
silent! call mkdir(&undodir, 'p')
set encoding=utf-8

" Editing
set breakindent
set expandtab
set foldmethod=manual
set gdefault
set hidden
set shiftwidth=2
set tabstop=2
set wrap

" Search
set hlsearch
set ignorecase
set incsearch
set smartcase

" UI
if has('macunix') | set clipboard=unnamed | else | set clipboard=unnamedplus | endif
set cmdheight=1
set colorcolumn=80
set completeopt=menuone,preview
set conceallevel=0
set laststatus=2
set list
set listchars=tab:▏\ ,trail:·,nbsp:␣
set mouse=
set number
set numberwidth=4
set pumheight=10
set relativenumber
set noruler
set noshowcmd
set noshowmode
set signcolumn=yes
set termguicolors
set title
set titlestring=%<%F%=%l/%L\ -\ vim

" Windows and timing
set scrolloff=10
set sidescrolloff=10
set splitbelow
set splitright
set timeout
set timeoutlen=300
set updatetime=100

" ── state ─────────────────────────────────────────────────────────────────────
let s:autosave_on = 1

" ── functions ─────────────────────────────────────────────────────────────────
function! s:GitFilesOrFiles()
  let root = system('git rev-parse --show-toplevel 2>/dev/null')
  if v:shell_error == 0
    execute 'GFiles'
  else
    execute 'Files'
  endif
endfunction

function! s:MkdirOnSave()
  let dir = expand('<afile>:p:h')
  if !isdirectory(dir)
    call mkdir(dir, 'p')
  endif
endfunction

function! s:NERDTreeFindOrClose()
  if exists('g:NERDTree') && g:NERDTree.IsOpen()
    NERDTreeClose
  else
    try
      NERDTreeFind
    catch
      NERDTree
    endtry
  endif
endfunction

function! s:ToggleAutoSave()
  if s:autosave_on
    autocmd! AutoSaveGroup
    let s:autosave_on = 0
    echo 'AutoSave disabled'
  else
    augroup AutoSaveGroup
      autocmd!
      autocmd CursorHold,InsertLeave * silent! update
    augroup END
    let s:autosave_on = 1
    echo 'AutoSave enabled'
  endif
endfunction

augroup AutoSaveGroup
  autocmd!
  autocmd CursorHold,InsertLeave * silent! update
augroup END

function! s:ToggleCopyPasteMode()
  if &number
    set nonumber norelativenumber signcolumn=no paste
    IndentLinesDisable
  else
    set number relativenumber signcolumn=yes nopaste
    IndentLinesEnable
  endif
endfunction

function! s:TrimTrailingWhitespace()
  let save = winsaveview()
  keeppatterns %s/\s\+$//e
  call winrestview(save)
endfunction

