" ── keymaps ───────────────────────────────────────────────────────────────────
" Core
nnoremap ; :
inoremap jk <Esc>
inoremap kj <Esc>
nnoremap <silent> <Esc> :nohlsearch<CR>

" Global marks: remap lowercase to uppercase so marks persist across files.
for s:c in split('abcdefghijklmnopqrstuvwxyz', '\zs')
  execute 'nnoremap m' . s:c . ' m' . toupper(s:c)
  execute "nnoremap '" . s:c . " '" . toupper(s:c)
  execute 'vnoremap m' . s:c . ' m' . toupper(s:c)
  execute "vnoremap '" . s:c . " '" . toupper(s:c)
endfor

" Insert-mode navigation
inoremap <C-h> <Left>
inoremap <C-j> <Down>
inoremap <C-k> <Up>
inoremap <C-l> <Right>
inoremap <C-v> <C-o>p

" Files and buffers
nnoremap <silent> <C-s> :w<CR>
vnoremap <silent> <C-s> <Esc>:w<CR>gv
inoremap <silent> <C-s> <Esc>:w<CR>a
nnoremap <silent> <Leader>bd :Bdelete<CR>
nnoremap <silent> <Leader>bo :bufdo Bdelete<CR>
nnoremap <silent> <S-l> :bnext<CR>
nnoremap <silent> <S-h> :bprev<CR>

" Quit
nnoremap <silent> <C-q> :confirm q<CR>
vnoremap <silent> <C-q> :<C-u>confirm q<CR>
inoremap <silent> <C-q> <Esc>:confirm q<CR>

" Windows
nnoremap <C-w>h :set nosplitright<CR>:vsplit<CR>:set splitright<CR>
nnoremap <C-w>j :set splitbelow<CR>:split<CR>
nnoremap <C-w>k :set nosplitbelow<CR>:split<CR>:set splitbelow<CR>
nnoremap <C-w>l :set splitright<CR>:vsplit<CR>
nnoremap <Leader>wh :set nosplitright<CR>:vsplit<CR>:set splitright<CR>
nnoremap <Leader>wj :set splitbelow<CR>:split<CR>
nnoremap <Leader>wk :set nosplitbelow<CR>:split<CR>:set splitbelow<CR>
nnoremap <Leader>wl :set splitright<CR>:vsplit<CR>

" Editing helpers
vnoremap < <gv
vnoremap > >gv
vnoremap <silent> <Leader>so :sort<CR>
vnoremap <silent> <Leader>sn :sort n<CR>

" Toggles
nnoremap <silent> <F2> :call <SID>ToggleCopyPasteMode()<CR>
vnoremap <silent> <F2> :<C-u>call <SID>ToggleCopyPasteMode()<CR>
nnoremap <silent> <Leader>as :call <SID>ToggleAutoSave()<CR>

" Quickfix
nnoremap <silent> ] :cnext<CR>
nnoremap <silent> [ :cprev<CR>

" Search
map /  <Plug>(incsearch-forward)
map ?  <Plug>(incsearch-backward)
map g/ <Plug>(incsearch-stay)
nnoremap <Leader>lg :Rg<CR>
nnoremap <Leader>gs :Rg <C-r><C-w><CR>
nnoremap <Leader>sr :Farr<CR>
vnoremap <Leader>sr :Farr<CR>

" Navigation plugins
map <Tab>   <Plug>Sneak_;
map <S-Tab> <Plug>Sneak_,
nnoremap <silent> <Leader>e :call <SID>NERDTreeFindOrClose()<CR>
vnoremap <silent> <Leader>e :<C-u>call <SID>NERDTreeFindOrClose()<CR>
nnoremap <Leader><Leader> :Buffers<CR>
nnoremap <Leader>f        :Files<CR>
nnoremap <Leader>gf       :GFiles<CR>
nnoremap <Leader>bf       :BLines<CR>
nnoremap <Leader>of       :History<CR>
nnoremap <Leader>ch       :History:<CR>
nnoremap <Leader>co       :Commands<CR>

" ALE — LSP keymaps (nvim-lspconfig equivalents)
nnoremap <silent> gd        :ALEGoToDefinition<CR>
nnoremap <silent> gr        :ALEFindReferences<CR>
nnoremap <silent> gi        :ALEGoToImplementation<CR>
nnoremap <silent> <Leader>rn :ALERename<CR>
nnoremap <silent> <Leader>ca :ALECodeAction<CR>
vnoremap <silent> <Leader>ca :ALECodeAction<CR>
nnoremap <silent> <Leader>dl :ALEDetail<CR>
nnoremap <silent> zj        :ALENextWrap<CR>
nnoremap <silent> zk        :ALEPreviousWrap<CR>

" ── autocmds ──────────────────────────────────────────────────────────────────
augroup vimrc
  autocmd!

  " Close Vim when NERDTree is the only window left.
  autocmd BufEnter * if winnr('$') == 1 && exists('b:NERDTree') && b:NERDTree.isTabTree() | quit | endif

  " Equalize windows on resize (VimResized autocmd).
  autocmd VimResized * wincmd =

  " Auto-create parent directories on save (mkdir.nvim).
  autocmd BufWritePre * call s:MkdirOnSave()

  " Trim trailing whitespace on save.
  autocmd BufWritePre * call s:TrimTrailingWhitespace()
augroup END

