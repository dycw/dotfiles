" close vim when NERDTree is the only window left
autocmd BufEnter * if winnr('$') == 1 && exists('b:NERDTree') && b:NERDTree.isTabTree() | quit | endif

function! s:NERDTreeFindOrClose()
  if exists('g:NERDTree') && g:NERDTree.IsOpen()
    NERDTreeClose
  else
    try
      NERDTreeFind
    catch
      NERDTree
    endtry
  endif
endfunction

