" vimrc — comprehensive config ported from neovim/lazy.nvim

" ── vim-plug: auto-install ────────────────────────────────────────────────────
let s:plug_file = expand('~/.vim/autoload/plug.vim')
if empty(glob(s:plug_file))
  silent execute '!curl -fLo ' . s:plug_file . ' --create-dirs '
    \ . 'https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim'
  autocmd VimEnter * PlugInstall --sync | source $MYVIMRC
endif

" ── plugins ───────────────────────────────────────────────────────────────────
call plug#begin('~/.vim/plugged')

" colorscheme (tokyonight.nvim)
Plug 'ghifarit53/tokyonight-vim'

" statusline + bufferline (lualine.nvim + bufferline.nvim)
Plug 'itchyny/lightline.vim'
Plug 'ap/vim-buftabline'

" file tree (nvim-tree.lua)
Plug 'preservim/nerdtree'

" fuzzy finding (telescope.nvim)
Plug 'junegunn/fzf', { 'do': { -> fzf#install() } }
Plug 'junegunn/fzf.vim'

" git (gitsigns.nvim + git-conflict.nvim)
Plug 'airblade/vim-gitgutter'
Plug 'rhysd/conflict-marker.vim'

" motions (leap.nvim)
Plug 'justinmk/vim-sneak'

" text objects (targets.vim + vim-matchup + wildfire.nvim)
Plug 'wellle/targets.vim'
Plug 'andymass/vim-matchup'
Plug 'michaeljsmith/vim-indent-object'
Plug 'gcmt/wildfire.vim'

" editing (nvim-surround + comment.nvim + vim-caser/text-case)
Plug 'tpope/vim-surround'
Plug 'tpope/vim-commentary'
Plug 'tpope/vim-repeat'
Plug 'tpope/vim-abolish'
Plug 'tpope/vim-unimpaired'
Plug 'tpope/vim-eunuch'
Plug 'tpope/vim-sleuth'

" pairs (nvim-autopairs)
Plug 'jiangmiao/auto-pairs'

" search/replace (grug-far.nvim)
Plug 'brooth/far.vim'

" linting + formatting + LSP (nvim-lint + conform.nvim + nvim-lspconfig)
Plug 'dense-analysis/ale'

" indent guides + rainbow (indent-blankline.nvim + rainbow-delimiters.nvim)
Plug 'Yggdroot/indentLine'
Plug 'luochen1990/rainbow'

" misc (vim-cool + vim-numbertoggle + vim-lastplace + vim-tmux-navigator)
Plug 'romainl/vim-cool'
Plug 'jeffkreeftmeijer/vim-numbertoggle'
Plug 'farmergreg/vim-lastplace'
Plug 'christoomey/vim-tmux-navigator'

" language support (rustaceanvim)
Plug 'rust-lang/rust.vim'

call plug#end()

" auto-install missing plugins on startup
autocmd VimEnter * if len(filter(values(g:plugs), '!isdirectory(v:val.dir)'))
  \| PlugInstall --sync | source $MYVIMRC
  \| endif

